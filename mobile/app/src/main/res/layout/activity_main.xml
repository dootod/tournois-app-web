<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tournois"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnTournois"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Voir les tournois"
        android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnMesTournois"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes inscriptions"
        android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mon profil"
        android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnScores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes scores"
        android:layout_marginBottom="32dp"/>

    <Button android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Déconnexion"/>
</LinearLayout>
