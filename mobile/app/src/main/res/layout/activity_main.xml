<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/header_gradient"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JUDO CLUB"
            android:textColor="#FFE0B2"
            android:textSize="12sp"
            android:letterSpacing="0.2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon espace"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout android:id="@+id/btnTournois"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <TextView android:text="Tournois disponibles" style="@style/CardTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Inscrivez-vous aux prochaines compétitions" style="@style/CardSubtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnMesTournois"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <TextView android:text="Mes inscriptions" style="@style/CardTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Vos tournois, vos équipes, vos matchs" style="@style/CardSubtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnScores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">
                <TextView android:text="Mes scores" style="@style/CardTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Historique de vos combats et résultats" style="@style/CardSubtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">
                <TextView android:text="Mon profil" style="@style/CardTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Modifier vos informations personnelles" style="@style/CardSubtitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <TextView android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Déconnexion"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="center"
                android:background="@drawable/btn_ghost_bg"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
