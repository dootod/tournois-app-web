{# ═══════════════════════════════════════════════════════════════════════════
   PARTIAL: Affichage amélioré des matchs
   ═══════════════════════════════════════════════════════════════════════════ #}

{% macro renderMatchModern(match, tournament, creneaux, tournamentId) %}
<div class="match-card" style="margin-bottom:16px;">
    
    {# ── En-tête ──────────────────────────────────────────────────────── #}
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:11px;color:var(--gris-moyen);font-weight:600;">MATCH #{{ match.id }}</span>
            {% if match.round %}
            <span style="background:rgba(var(--accent-rgb), 0.2);color:var(--accent);padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600;">{{ match.round }}</span>
            {% endif %}
        </div>
        <span style="font-size:11px;color:var(--gris-moyen);">
            {% if match.tatami %}<span>🥋 T{{ match.tatami }}</span>{% endif %}
            {% if match.heure_debut %}
            <span style="margin-left:8px;">🕐 {{ match.heure_debut|date('H:i') }}
                {%- if match.heure_fin %} – {{ match.heure_fin|date('H:i') }}{% endif %}</span>
            {% endif %}
        </span>
    </div>

    {# ── Combattants ──────────────────────────────────────────────────── #}
    <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:center;">
        
        {# Combattant 1 #}
        <div style="background:rgba(255,255,255,.03);padding:10px;border-radius:6px;border:1px solid rgba(255,255,255,.08);">
            <div style="font-size:12px;font-weight:500;">
                {% if tournament.equipe %}
                    {{ match.equipe1 ? match.equipe1.nom : '?' }}
                {% else %}
                    {{ match.participant1 and match.participant1.adherent ? match.participant1.adherent.prenom ~ ' ' ~ match.participant1.adherent.nom : '?' }}
                {% endif %}
            </div>
            {% if match.scores %}
            <div style="font-size:13px;font-weight:600;margin-top:6px;color:var(--accent);">
                {% for score in match.scores %}
                    {% if (not tournament.equipe and score.participant1_id == match.participant1_id) or (tournament.equipe and score.equipe1_id == match.equipe1_id) %}
                        {{ score.winner ? '✓ ' : '' }}{{ score.score1 ?? '—' }}
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </div>

        {# VS ──────────────────────────────────────────────────────────── #}
        <div style="text-align:center;color:var(--gris-moyen);font-size:11px;font-weight:600;">VS</div>

        {# Combattant 2 #}
        <div style="background:rgba(255,255,255,.03);padding:10px;border-radius:6px;border:1px solid rgba(255,255,255,.08);">
            <div style="font-size:12px;font-weight:500;">
                {% if tournament.equipe %}
                    {{ match.equipe2 ? match.equipe2.nom : '?' }}
                {% else %}
                    {{ match.participant2 and match.participant2.adherent ? match.participant2.adherent.prenom ~ ' ' ~ match.participant2.adherent.nom : '?' }}
                {% endif %}
            </div>
            {% if match.scores %}
            <div style="font-size:13px;font-weight:600;margin-top:6px;color:var(--accent);">
                {% for score in match.scores %}
                    {% if (not tournament.equipe and score.participant2_id == match.participant2_id) or (tournament.equipe and score.equipe2_id == match.equipe2_id) %}
                        {{ score.winner == false ? '✓ ' : '' }}{{ score.score2 ?? '—' }}
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Actions ──────────────────────────────────────────────────────── #}
    <div style="display:flex;gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08);">
        
        {% if not tournament.equipe %}
        {# Score individual #}
        <details style="flex:1;">
            <summary style="cursor:pointer;font-size:11px;color:var(--accent);font-weight:600;padding:8px;border-radius:4px;background:rgba(var(--accent-rgb),.1);transition:all .2s;">
                📊 Saisir le résultat
            </summary>
            <form method="post" action="{{ path('app_tournoi_match_score_add', {id:tournamentId, matchId:match.id}) }}" style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <input type="number" name="score1" placeholder="Score 1" class="form-control" style="padding:8px;font-size:12px;" required>
                <input type="number" name="score2" placeholder="Score 2" class="form-control" style="padding:8px;font-size:12px;" required>
                <div style="grid-column:span 2;">
                    <label style="display:flex;align-items:center;gap:6px;font-size:11px;margin-bottom:8px;">
                        <input type="radio" name="winner_participant_id" value="{{ match.participant1_id }}" required>
                        Vainqueur : {{ match.participant1.adherent.prenom }} {{ match.participant1.adherent.nom }}
                    </label>
                    <label style="display:flex;align-items:center;gap:6px;font-size:11px;">
                        <input type="radio" name="winner_participant_id" value="{{ match.participant2_id }}" required>
                        Vainqueur : {{ match.participant2.adherent.prenom }} {{ match.participant2.adherent.nom }}
                    </label>
                </div>
                <button type="submit" class="btn btn-sm btn-primary" style="grid-column:span 2;font-size:11px;padding:6px;margin-top:8px;">Valider</button>
            </form>
        </details>
        {% else %}
        {# Score équipe #}
        <details style="flex:1;">
            <summary style="cursor:pointer;font-size:11px;color:var(--accent);font-weight:600;padding:8px;border-radius:4px;background:rgba(var(--accent-rgb),.1);transition:all .2s;">
                📊 Saisir le résultat
            </summary>
            <form method="post" action="{{ path('app_tournoi_match_resultat_equipe', {id:tournamentId, matchId:match.id}) }}" style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <input type="number" name="score_equipe1" placeholder="Score" class="form-control" value="{{ match.score_equipe1 ?? '' }}" style="padding:8px;font-size:12px;" required>
                <input type="number" name="score_equipe2" placeholder="Score" class="form-control" value="{{ match.score_equipe2 ?? '' }}" style="padding:8px;font-size:12px;" required>
                <button type="submit" class="btn btn-sm btn-primary" style="grid-column:span 2;font-size:11px;padding:6px;margin-top:8px;">Valider</button>
            </form>
        </details>
        {% endif %}

        {# Planification #}
        <details style="flex:1;">
            <summary style="cursor:pointer;font-size:11px;color:var(--accent);font-weight:600;padding:8px;border-radius:4px;background:rgba(var(--accent-rgb),.1);transition:all .2s;">
                🕐 Planifier
            </summary>
            <form method="post" action="{{ path('app_tournoi_match_planifier', {id:tournamentId, matchId:match.id}) }}" style="margin-top:10px;display:grid;grid-template-columns:1fr;gap:8px;">
                <select name="tatami" class="form-control" style="padding:8px;font-size:12px;">
                    <option value="">— Tatami —</option>
                    <option value="1" {{ match.tatami == 1 ? 'selected' : '' }}>Tatami 1</option>
                    <option value="2" {{ match.tatami == 2 ? 'selected' : '' }}>Tatami 2</option>
                    <option value="3" {{ match.tatami == 3 ? 'selected' : '' }}>Tatami 3</option>
                </select>
                <select name="heure_debut" class="form-control" style="padding:8px;font-size:12px;">
                    <option value="">— Début —</option>
                    {% for c in creneaux %}
                    <option value="{{ c }}" {{ match.heure_debut and match.heure_debut|date('H:i') == c ? 'selected' : '' }}>{{ c }}</option>
                    {% endfor %}
                </select>
                <select name="heure_fin" class="form-control" style="padding:8px;font-size:12px;">
                    <option value="">— Fin —</option>
                    {% for c in creneaux %}
                    <option value="{{ c }}" {{ match.heure_fin and match.heure_fin|date('H:i') == c ? 'selected' : '' }}>{{ c }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="btn btn-sm btn-primary" style="font-size:11px;padding:6px;margin-top:8px;">Attribuer</button>
            </form>
        </details>

        {# Supprimer #}
        <form method="post" action="{{ path('app_tournoi_match_delete', {id:tournamentId, matchId:match.id}) }}" onsubmit="return confirm('Supprimer ce match ?')" style="align-self:flex-start;">
            <button type="submit" class="btn btn-danger btn-sm" style="font-size:11px;padding:8px;border-radius:4px;">🗑️</button>
        </form>
    </div>
</div>
{% endmacro %}
