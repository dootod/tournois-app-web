{% extends 'base.html.twig' %}

{% block title %}Dashboard — Judo Club{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block topbar_actions %}
    <a href="{{ path('app_tournoi_new') }}" class="btn btn-primary btn-sm">+ Nouveau tournoi</a>
    <a href="{{ path('app_adherent_new') }}" class="btn btn-secondary btn-sm">+ Adhérent</a>
{% endblock %}

{% block body %}

<div class="page-header">
    <div class="page-header-left">
        <div class="page-eyebrow">Vue d'ensemble</div>
        <h1>Dashboard</h1>
        <div class="page-subtitle">Gestion du club et des tournois de judo</div>
    </div>
</div>

{# ── STATS ────────────────────────────────────────────────────────────────── #}
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Adhérents</div>
        <div class="stat-value">{{ nb_adherents }}</div>
        <div class="stat-sub">membres actifs</div>
    </div>
    <div class="stat-card green">
        <div class="stat-label">Tournois</div>
        <div class="stat-value">{{ nb_tournois }}</div>
        <div class="stat-sub">{{ tournois_en_cours }} en cours · {{ tournois_ouverts }} ouverts</div>
    </div>
    <div class="stat-card blue">
        <div class="stat-label">Participants</div>
        <div class="stat-value">{{ nb_participants }}</div>
        <div class="stat-sub">inscriptions totales</div>
    </div>
</div>

{# ── DEUX COLONNES ────────────────────────────────────────────────────────── #}
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

    {# Tournois récents #}
    <div class="card">
        <div class="card-header">
            <span class="card-title">Tournois récents</span>
            <a href="{{ path('app_tournois') }}" class="btn btn-ghost btn-sm">Voir tout</a>
        </div>
        {% if tournois_recents is empty %}
            <div class="empty-state">
                <div class="empty-icon">🏆</div>
                <p>Aucun tournoi créé</p>
                <a href="{{ path('app_tournoi_new') }}" class="btn btn-primary btn-sm">Créer un tournoi</a>
            </div>
        {% else %}
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Tournoi</th>
                            <th>Date</th>
                            <th>État</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in tournois_recents %}
                        <tr>
                            <td>
                                <a href="{{ path('app_tournoi_show', {id: t.id}) }}" style="color: var(--blanc); text-decoration: none; font-weight: 500;">
                                    Tournoi #{{ t.id }}
                                </a>
                                {% if t.equipe %}
                                    <span class="badge badge-blue" style="margin-left: 6px;">équipe</span>
                                {% endif %}
                            </td>
                            <td class="text-muted text-mono" style="font-size: 12px;">
                                {{ t.date ? t.date|date('d/m/Y') : '—' }}
                            </td>
                            <td>
                                {% if t.etat == 'ouvert' %}
                                    <span class="badge badge-green">ouvert</span>
                                {% elseif t.etat == 'en_cours' %}
                                    <span class="badge badge-orange">en cours</span>
                                {% elseif t.etat == 'termine' %}
                                    <span class="badge badge-grey">terminé</span>
                                {% else %}
                                    <span class="badge badge-red">{{ t.etat }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    {# Adhérents récents #}
    <div class="card">
        <div class="card-header">
            <span class="card-title">Adhérents récents</span>
            <a href="{{ path('app_adherents') }}" class="btn btn-ghost btn-sm">Voir tout</a>
        </div>
        {% if adherents_recents is empty %}
            <div class="empty-state">
                <div class="empty-icon">👤</div>
                <p>Aucun adhérent</p>
                <a href="{{ path('app_adherent_new') }}" class="btn btn-primary btn-sm">Ajouter un adhérent</a>
            </div>
        {% else %}
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Adhérent</th>
                            <th>Ceinture</th>
                            <th>Adhésion</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for a in adherents_recents %}
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div class="avatar-initials">
                                        {{ a.nom|first }}{{ a.prenom|first }}
                                    </div>
                                    <span style="font-weight: 500;">{{ a.prenom }} {{ a.nom }}</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-mono" style="font-size: 12px; color: var(--gris-clair);">
                                    {{ a.ceinture }}
                                </span>
                            </td>
                            <td class="text-muted text-mono" style="font-size: 12px;">
                                {{ a.date_adhesion ? a.date_adhesion|date('d/m/Y') : '—' }}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

</div>

{% endblock %}
